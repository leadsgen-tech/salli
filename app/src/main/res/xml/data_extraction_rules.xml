<?xml version="1.0" encoding="utf-8"?>
<!-- Salli stores financial data locally. We disallow backup/transfer entirely
     so data cannot leak to Google Drive or another device without the user
     explicitly using our export. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
    </device-transfer>
</data-extraction-rules>
